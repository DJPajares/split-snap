# ─── API Server ───────────────────────────────────
API_PORT=3001
MONGODB_URI=mongodb://localhost:27017/split-snap
JWT_SECRET=change-this-to-a-secure-random-string
FRONTEND_URL=http://localhost:3000

# ─── Receipt Scanner ──────────────────────────────
# Provider: "auto" (default) | "gemini" | "openai" | "tesseract"
# auto tries in order: gemini → openai → tesseract
RECEIPT_SCANNER_PROVIDER=auto

# Gemini (free) — get key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# OpenAI (paid) — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Tesseract needs no API key — works offline

# ─── Frontend ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
