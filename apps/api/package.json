{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @split-snap/shared build",
    "dev": "tsx watch --env-file=../../.env src/dev.ts",
    "prebuild": "pnpm --filter @split-snap/shared build",
    "build": "tsc",
    "prestart": "pnpm --filter @split-snap/shared build",
    "start": "node --env-file=../../.env dist/dev.js",
    "prestart:prod": "pnpm --filter @split-snap/shared build",
    "start:prod": "node dist/dev.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@hono/node-server": "^1.19.9",
    "@split-snap/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.3",
    "openai": "^6.25.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
