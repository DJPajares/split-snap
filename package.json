{
  "name": "split-snap",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "pnpm -r run lint:fix",
    "clean": "turbo clean",
    "test": "turbo test",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,mdx,yml,yaml,css,scss}": [
      "prettier --write"
    ],
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter web exec eslint --fix --max-warnings=0",
      "pnpm --filter web exec vitest related --run --passWithNoTests"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
